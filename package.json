{
  "name": "paygate",
  "version": "0.1.0",
  "private": true,
  "description": "PayGate — Sovereign payment + identity layer for AI agents. x402 + ERC-8004 on Base.",
  "license": "MIT",
  "workspaces": [
    "contracts",
    "sdk",
    "demo"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "build:contracts": "cd contracts && npm run compile",
    "build:sdk": "cd sdk && npm run build",
    "test:contracts": "cd contracts && npm test",
    "test:sdk": "cd sdk && npm test",
    "dev:demo": "cd demo && npm run dev"
  }
}
